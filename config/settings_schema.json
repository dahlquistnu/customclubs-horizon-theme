[
  {
    "name": "theme_info",
    "theme_name": "Custom Clubs — Horizon",
    "theme_version": "1.0.0",
    "theme_author": "Custom Clubs SE",
    "theme_documentation_url": "https://shopify.dev/docs/themes",
    "theme_support_url": "https://customclubs.se"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Accent colors"
      },
      {
        "type": "color",
        "id": "colors_accent_1",
        "label": "Accent 1 (Primary Green)",
        "default": "#00E697"
      },
      {
        "type": "color",
        "id": "colors_accent_2",
        "label": "Accent 2 (Dark Green)",
        "default": "#00352B"
      },
      {
        "type": "header",
        "content": "Buttons"
      },
      {
        "type": "color",
        "id": "colors_solid_button_labels",
        "label": "Solid button label",
        "default": "#001914"
      },
      {
        "type": "color",
        "id": "colors_outline_button_labels",
        "label": "Outline button label",
        "default": "#00E697"
      },
      {
        "type": "header",
        "content": "Text & background"
      },
      {
        "type": "color",
        "id": "colors_text",
        "label": "Body text",
        "default": "#222222"
      },
      {
        "type": "color",
        "id": "colors_background_1",
        "label": "Background 1 (light)",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "colors_background_2",
        "label": "Background 2 (dark)",
        "default": "#001914"
      },
      {
        "type": "header",
        "content": "Cards"
      },
      {
        "type": "color",
        "id": "colors_card_background",
        "label": "Card background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "colors_card_border",
        "label": "Card border",
        "default": "#e2e2e2"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Headings"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Headings font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "header",
        "content": "Body"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body font",
        "default": "helvetica_neue_n4"
      },
      {
        "type": "range",
        "id": "font_size_scale",
        "label": "Body font size scale",
        "min": 80,
        "max": 120,
        "step": 5,
        "unit": "%",
        "default": 100
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "label": "Page width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "unit": "px",
        "default": 1400
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "label": "Space between sections",
        "min": 0,
        "max": 60,
        "step": 4,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "Buttons & inputs",
    "settings": [
      {
        "type": "range",
        "id": "buttons_border_radius",
        "label": "Button border radius",
        "min": 0,
        "max": 70,
        "step": 2,
        "unit": "px",
        "default": 70
      },
      {
        "type": "range",
        "id": "inputs_border_radius",
        "label": "Input border radius",
        "min": 0,
        "max": 40,
        "step": 2,
        "unit": "px",
        "default": 25
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 140
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" },
          { "value": "notification", "label": "Notification" }
        ],
        "default": "drawer"
      },
      {
        "type": "select",
        "id": "cart_icon",
        "label": "Cart icon",
        "options": [
          { "value": "cart", "label": "Cart" },
          { "value": "bag", "label": "Bag" }
        ],
        "default": "bag"
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "label": "Enable predictive search",
        "default": true
      }
    ]
  },
  {
    "name": "Currency & language",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_currency_selector",
        "label": "Enable currency selector",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_language_selector",
        "label": "Enable language selector",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "currency_code_enabled",
        "label": "Show currency code",
        "default": true
      }
    ]
  },
  {
    "name": "Product grid",
    "settings": [
      {
        "type": "select",
        "id": "product_grid_image_ratio",
        "label": "Image ratio",
        "options": [
          { "value": "adapt", "label": "Adapt to image" },
          { "value": "portrait", "label": "Portrait (2:3)" },
          { "value": "square", "label": "Square (1:1)" },
          { "value": "landscape", "label": "Landscape (4:3)" }
        ],
        "default": "square"
      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "show_product_badges",
        "label": "Show sale badges",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram",
        "info": "https://instagram.com/yourhandle"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "YouTube"
      }
    ]
  }
]
