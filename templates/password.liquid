<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{- 'custom.css' | asset_url | stylesheet_tag -}}
    <style>
      body { background: #001914; color: #fff; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; font-family: 'Helvetica Neue', sans-serif; }
      .password-page { text-align: center; padding: 40px 20px; }
      .password-page h1 { font-size: 32px; color: #00E697; margin-bottom: 16px; }
      .password-page p { color: rgba(255,255,255,0.7); margin-bottom: 24px; }
      .password-page input { height: 48px; border-radius: 25px; border: none; padding: 0 20px; font-size: 14px; width: 280px; }
      .password-page button { height: 48px; padding: 0 28px; border-radius: 70px; background: #00E697; color: #001914; border: none; font-size: 15px; cursor: pointer; margin-left: 8px; }
    </style>
  </head>
  <body>
    <div class="password-page">
      <h1>{{ shop.name }}</h1>
      <p>{{ 'general.password_page.opening_soon' | t }}</p>
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <input type="password" name="password" placeholder="Password" autocomplete="current-password">
        <button type="submit">Enter</button>
      {% endform %}
    </div>
    {{ content_for_layout }}
  </body>
</html>
