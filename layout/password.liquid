<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#001914">
    <title>{{ shop.name }} — Coming Soon</title>
    {{ content_for_header }}
    {{- 'custom.css' | asset_url | stylesheet_tag -}}
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #001914;
        color: #fff;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }
      .password-page { text-align: center; max-width: 440px; width: 100%; }
      .password-page__logo { margin-bottom: 32px; }
      .password-page__logo a { color: #00E697; font-size: 28px; font-weight: 600; text-decoration: none; }
      .password-page__heading { font-size: 32px; font-weight: 400; color: #fff; margin-bottom: 12px; }
      .password-page__subtext { font-size: 15px; color: rgba(255,255,255,0.6); margin-bottom: 32px; line-height: 1.5; }
      .password-page__form { display: flex; gap: 0; }
      .password-page__form input {
        flex: 1;
        height: 52px;
        border-radius: 25px 0 0 25px;
        border: 1px solid rgba(255,255,255,0.2);
        border-right: none;
        background: rgba(255,255,255,0.08);
        color: #fff;
        padding: 0 20px;
        font-size: 15px;
        outline: none;
      }
      .password-page__form input::placeholder { color: rgba(255,255,255,0.4); }
      .password-page__form button {
        height: 52px;
        padding: 0 24px;
        border-radius: 0 25px 25px 0;
        background: #00E697;
        color: #001914;
        border: none;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s;
      }
      .password-page__form button:hover { background: #00d389; }
      .password-page__errors { color: #ff6b6b; font-size: 14px; margin-top: 12px; }
      .password-page__admin {
        margin-top: 40px;
        font-size: 13px;
        color: rgba(255,255,255,0.4);
      }
      .password-page__admin a { color: rgba(255,255,255,0.6); }
    </style>
  </head>
  <body>
    <div class="password-page">
      <div class="password-page__logo">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}">
            <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name | escape }}" width="200" height="60" style="max-height:60px; width:auto;">
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}">{{ shop.name | escape }}</a>
        {%- endif -%}
      </div>

      <h1 class="password-page__heading">Kommer snart</h1>
      <p class="password-page__subtext">Vi förbereder något fantastiskt. Ange lösenordet för att få tillgång.</p>

      {%- form 'storefront_password', class: 'password-page__form' -%}
        {%- if form.errors -%}
          <p class="password-page__errors">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <input
          type="password"
          name="password"
          placeholder="Lösenord"
          autocomplete="current-password"
          required
        >
        <button type="submit">Öppna</button>
      {%- endform -%}

      <p class="password-page__admin">
        Butiksägare? <a href="/admin">Logga in här</a>
      </p>
    </div>

    {{ content_for_layout }}
  </body>
</html>
