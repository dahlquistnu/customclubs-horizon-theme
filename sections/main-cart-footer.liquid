{%- if cart.item_count > 0 -%}
  <section class="cart-footer page-width" style="padding-bottom:60px;">
    <div style="max-width:400px; margin-left:auto;">
      <div style="background:#f7f7f7; border-radius:12px; padding:24px; margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
          <span style="font-size:14px; color:#666;">Delsumma</span>
          <span style="font-size:14px; color:#222;">{{ cart.total_price | money }}</span>
        </div>
        <p style="font-size:12px; color:#999; margin:0;">Frakt beräknas i kassan.</p>
      </div>

      <button
        type="submit"
        form="cart-form"
        name="checkout"
        style="width:100%; height:56px; border-radius:70px; background:#00352B; color:#00E697; border:none; font-size:16px; font-weight:500; cursor:pointer; margin-bottom:12px; transition:background 0.2s;"
        onmouseover="this.style.background='#00483a'" onmouseout="this.style.background='#00352B'"
      >
        Till kassan — {{ cart.total_price | money }}
      </button>

      <a
        href="{{ routes.root_url }}"
        style="display:block; text-align:center; font-size:14px; color:#666; text-decoration:underline; padding:8px;"
      >
        Fortsätt handla
      </a>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Cart footer",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
