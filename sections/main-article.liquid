<section class="main-article page-width" style="padding-block:48px; max-width:780px; margin:0 auto;">
  <p style="font-size:13px; color:#999; margin:0 0 8px;">{{ article.published_at | date: '%d %B %Y' }}</p>
  <h1 style="font-size:36px; font-weight:400; color:#001914; margin:0 0 24px; line-height:1.2;">{{ article.title | escape }}</h1>

  {%- if article.image -%}
    <div style="border-radius:12px; overflow:hidden; margin-bottom:32px; aspect-ratio:16/9;">
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.image.alt | escape }}" loading="eager" style="width:100%; height:100%; object-fit:cover;">
    </div>
  {%- endif -%}

  <div style="font-size:16px; line-height:1.8; color:#333;">
    {{ article.content }}
  </div>

  <div style="margin-top:48px; padding-top:24px; border-top:1px solid #e2e2e2;">
    <a href="{{ blog.url }}" style="display:inline-flex; align-items:center; gap:8px; color:#00352B; font-size:14px; font-weight:500; text-decoration:none;">&larr; Tillbaka till {{ blog.title | escape }}</a>
  </div>
</section>

{% schema %}
{ "name": "Article", "tag": "section", "class": "section", "settings": [] }
{% endschema %}
