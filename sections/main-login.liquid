<section class="main-login page-width" style="padding-block:60px; max-width:440px; margin:0 auto;">
  <h1 style="font-size:28px; font-weight:400; color:#001914; margin:0 0 8px; text-align:center;">Logga in</h1>
  <p style="font-size:14px; color:#666; text-align:center; margin:0 0 32px;">Välkommen tillbaka!</p>

  {%- form 'customer_login' -%}
    {{ form.errors | default_errors }}
    <div style="margin-bottom:16px;">
      <label for="email" style="display:block; font-size:13px; color:#444; margin-bottom:6px;">E-post</label>
      <input type="email" name="customer[email]" id="email" autocomplete="email" required style="width:100%; height:48px; border:1px solid #e2e2e2; border-radius:25px; padding:0 20px; font-size:14px; box-sizing:border-box; outline:none;">
    </div>
    <div style="margin-bottom:24px;">
      <label for="password" style="display:block; font-size:13px; color:#444; margin-bottom:6px;">Lösenord</label>
      <input type="password" name="customer[password]" id="password" autocomplete="current-password" required style="width:100%; height:48px; border:1px solid #e2e2e2; border-radius:25px; padding:0 20px; font-size:14px; box-sizing:border-box; outline:none;">
    </div>
    <button type="submit" style="width:100%; height:52px; border-radius:70px; background:#00352B; color:#00E697; border:none; font-size:15px; font-weight:500; cursor:pointer; margin-bottom:16px;">Logga in</button>
    <div style="text-align:center;">
      <a href="{{ routes.account_recover_url }}" style="font-size:13px; color:#666; text-decoration:underline;">Glömt lösenord?</a>
    </div>
  {%- endform -%}

  <p style="text-align:center; font-size:14px; color:#666; margin-top:24px; padding-top:24px; border-top:1px solid #e2e2e2;">
    Inget konto? <a href="{{ routes.account_register_url }}" style="color:#00352B; font-weight:500;">Skapa konto</a>
  </p>
</section>

{% schema %}
{ "name": "Login", "tag": "section", "class": "section", "settings": [] }
{% endschema %}
