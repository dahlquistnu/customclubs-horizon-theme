{%- if section.settings.collection != blank -%}
  {%- assign collection = collections[section.settings.collection] -%}
{%- endif -%}

<section class="featured-collection section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
        <h2 class="featured-collection__title">{{ section.settings.title | escape }}</h2>
        {%- if collection != blank and section.settings.show_view_all -%}
          <a href="{{ collection.url }}" class="button button--secondary" style="font-size:14px; padding:8px 20px;">
            Se alla
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank -%}
      <ul class="grid grid--{{ section.settings.columns_desktop }}-col-desktop" role="list"
          style="display:grid; grid-template-columns:repeat({{ section.settings.columns_desktop }},1fr); gap:16px; list-style:none; padding:0; margin:0;">
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          <li class="card-wrapper">
            <a href="{{ product.url }}" class="card product-card" style="display:block; text-decoration:none;">
              <div style="aspect-ratio:1; overflow:hidden; background:#f5f5f5;">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 400 }}"
                    alt="{{ product.featured_image.alt | default: product.title | escape }}"
                    loading="lazy"
                    width="400"
                    height="400"
                    style="width:100%; height:100%; object-fit:contain;"
                  >
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              {%- if section.settings.show_badges and product.compare_at_price > product.price -%}
                <span class="badge--sale">Sale</span>
              {%- endif -%}

              <div class="card__information" style="padding:12px;">
                <h3 class="card__heading" style="font-size:14px; margin:0 0 6px;">{{ product.title | escape }}</h3>
                <div class="price">
                  {%- if product.compare_at_price > product.price -%}
                    <span style="color:#cc0000; font-size:16px;">{{ product.price | money }}</span>
                    <span style="text-decoration:line-through; color:#999; font-size:13px; margin-left:6px;">{{ product.compare_at_price | money }}</span>
                  {%- else -%}
                    <span style="font-size:16px;">{{ product.price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          </li>
        {%- else -%}
          {%- for i in (1..section.settings.products_to_show) -%}
            <li class="card-wrapper">
              <div class="card product-card">
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                <div class="card__information" style="padding:12px;">
                  <h3 class="card__heading">Exempelprodukt</h3>
                  <p class="price">{{ 1999 | money }}</p>
                </div>
              </div>
            </li>
          {%- endfor -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</section>

<style>
  @media (max-width: 990px) {
    #shopify-section-{{ section.id }} ul {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
  @media (max-width: 750px) {
    #shopify-section-{{ section.id }} ul {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Utvalda produkter"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Products to show",
      "default": 5
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show 'View all' link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Show sale badges",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
