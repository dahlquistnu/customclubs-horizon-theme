<section class="main-search page-width" style="padding-block:40px;">
  <h1 style="font-size:28px; font-weight:400; color:#001914; margin:0 0 24px;">
    {%- if search.performed -%}
      Sökresultat för "{{ search.terms | escape }}"
    {%- else -%}
      Sök
    {%- endif -%}
  </h1>

  <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex; gap:0; max-width:560px; margin-bottom:40px;">
    <input type="hidden" name="type" value="product">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Sök produkter..."
      aria-label="Sök produkter"
      style="flex:1; height:52px; border-radius:25px 0 0 25px; border:1px solid rgba(0,53,43,0.3); border-right:none; padding:0 20px; font-size:15px; outline:none; color:#222;"
    >
    <button
      type="submit"
      style="height:52px; padding:0 28px; background:#001914; color:#00E697; border:none; border-radius:0 25px 25px 0; font-size:15px; cursor:pointer; font-weight:500; white-space:nowrap;"
    >
      Sök
    </button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <div style="padding:40px 0; text-align:center;">
        <p style="color:#666; font-size:17px; margin:0 0 8px;">Inga produkter hittades för "<strong>{{ search.terms | escape }}</strong>".</p>
        <p style="color:#999; font-size:14px; margin:0;">Prova ett annat sökord eller bläddra i våra kategorier.</p>
      </div>
    {%- else -%}
      <p style="color:#666; font-size:14px; margin-bottom:24px;">
        {{ search.results_count }} resultat för "<strong>{{ search.terms | escape }}</strong>"
      </p>
      {%- paginate search.results by 24 -%}
        <ul style="display:grid; grid-template-columns:repeat(4,1fr); gap:20px; list-style:none; padding:0; margin:0 0 40px;" role="list">
          {%- for item in search.results -%}
            <li>
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <div style="text-align:center; padding-top:24px;">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  {%- endif -%}
</section>

<style>
  @media (max-width: 990px) { .main-search ul { grid-template-columns: repeat(3,1fr) !important; } }
  @media (max-width: 750px) { .main-search ul { grid-template-columns: repeat(2,1fr) !important; gap: 12px !important; } }
</style>

{% schema %}
{ "name": "Search results", "tag": "section", "class": "section", "settings": [] }
{% endschema %}
