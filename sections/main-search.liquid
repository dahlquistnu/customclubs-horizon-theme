<section class="main-search page-width" style="padding-block:40px;">
  <h1 style="font-size:28px; font-weight:400; color:#001914; margin:0 0 24px;">Sök</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" style="display:flex; gap:0; max-width:500px; margin-bottom:40px;">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="Sök produkter..."
      style="flex:1; height:52px; border-radius:25px 0 0 25px; border:1px solid #e2e2e2; border-right:none; padding:0 20px; font-size:15px; outline:none;"
    >
    <button type="submit" style="height:52px; padding:0 24px; background:#00352B; color:#00E697; border:none; border-radius:0 25px 25px 0; font-size:15px; cursor:pointer;">Sök</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p style="color:#666; font-size:15px;">Inga resultat för "<strong>{{ search.terms | escape }}</strong>".</p>
    {%- else -%}
      <p style="color:#666; font-size:14px; margin-bottom:24px;">{{ search.results_count }} resultat för "<strong>{{ search.terms | escape }}</strong>"</p>
      {%- paginate search.results by 24 -%}
        <ul style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px; list-style:none; padding:0; margin:0;" role="list">
          {%- for item in search.results -%}
            <li>
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', product: item %}
              {%- else -%}
                <a href="{{ item.url }}" style="display:block; padding:16px; border:1px solid #e2e2e2; border-radius:8px; text-decoration:none; color:#222;">
                  <h3 style="font-size:15px; margin:0 0 8px;">{{ item.title | escape }}</h3>
                  <p style="font-size:13px; color:#666; margin:0;">{{ item.content | strip_html | truncate: 100 }}</p>
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endpaginate -%}
    {%- endif -%}
  {%- endif -%}
</section>

<style>
  @media (max-width: 750px) { .main-search ul { grid-template-columns: repeat(2,1fr) !important; } }
</style>

{% schema %}
{ "name": "Search results", "tag": "section", "class": "section", "settings": [] }
{% endschema %}
