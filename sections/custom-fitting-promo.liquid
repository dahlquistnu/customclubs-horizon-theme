<section class="custom-fitting-promo" style="background:#001914; padding-block:80px;">
  <div style="max-width:1400px; margin:0 auto; padding-inline:15px; display:flex; align-items:center; gap:60px; flex-wrap:wrap;">

    {%- if section.settings.image != blank -%}
      <div style="flex:1; min-width:280px; border-radius:12px; overflow:hidden; aspect-ratio:4/3;">
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | escape }}"
          width="800"
          height="600"
          loading="lazy"
          style="width:100%; height:100%; object-fit:cover;"
        >
      </div>
    {%- endif -%}

    <div style="flex:1; min-width:280px; color:#fff;">
      {%- if section.settings.label != blank -%}
        <p style="font-size:13px; color:#00E697; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; margin:0 0 12px;">{{ section.settings.label | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 style="font-size:46px; font-weight:400; color:#fff; line-height:1.1; margin:0 0 16px;">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p style="font-size:17px; line-height:1.65; color:rgba(255,255,255,0.8); margin:0 0 32px;">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        {%- if section.settings.button_label_1 != blank -%}
          <a
            href="{{ section.settings.button_link_1 }}"
            style="display:inline-flex; align-items:center; height:50px; padding:0 28px; background:#00E697; color:#001914; border-radius:50px; font-size:15px; font-weight:500; text-decoration:none; transition:background 0.2s; white-space:nowrap;"
          >
            {{ section.settings.button_label_1 | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank -%}
          <a
            href="{{ section.settings.button_link_2 }}"
            style="display:inline-flex; align-items:center; height:50px; padding:0 28px; background:transparent; color:#fff; border:1px solid rgba(255,255,255,0.5); border-radius:50px; font-size:15px; font-weight:400; text-decoration:none; transition:border-color 0.2s; white-space:nowrap;"
          >
            {{ section.settings.button_label_2 | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Fitting Promo",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (small text)",
      "default": "Fitting Centers i Göteborg"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upplev custom fitting på riktigt"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Boka en tid med en av våra experter och hitta de perfekta klubborna för ditt spel."
    },
    {
      "type": "text",
      "id": "button_label_1",
      "label": "Primary button label",
      "default": "Boka tid för custom fitting"
    },
    {
      "type": "url",
      "id": "button_link_1",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Secondary button label",
      "default": "Läs mer om custom fitting"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Custom Fitting Promo"
    }
  ]
}
{% endschema %}
