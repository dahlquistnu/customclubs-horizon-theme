<section class="main-cart page-width" style="padding-block:40px;">
  <h1 style="font-size:28px; font-weight:400; color:#001914; margin:0 0 32px;">Din kundvagn</h1>

  {%- if cart.item_count == 0 -%}
    <div style="text-align:center; padding:60px 20px;">
      <p style="font-size:18px; color:#666; margin-bottom:24px;">Din kundvagn är tom.</p>
      <a href="{{ routes.root_url }}" class="button button--primary" style="display:inline-flex; align-items:center; height:52px; padding:0 36px; border-radius:70px; background:#00352B; color:#00E697; text-decoration:none; font-size:16px;">
        Fortsätt handla
      </a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" id="cart-form">
      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr style="border-bottom:2px solid #e2e2e2;">
            <th style="text-align:left; padding-bottom:12px; font-size:13px; font-weight:500; color:#666; text-transform:uppercase; letter-spacing:0.06em;">Produkt</th>
            <th style="text-align:center; padding-bottom:12px; font-size:13px; font-weight:500; color:#666; text-transform:uppercase; letter-spacing:0.06em;">Antal</th>
            <th style="text-align:right; padding-bottom:12px; font-size:13px; font-weight:500; color:#666; text-transform:uppercase; letter-spacing:0.06em;">Pris</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr style="border-bottom:1px solid #e2e2e2;">
              <td style="padding:20px 0; vertical-align:middle;">
                <div style="display:flex; gap:16px; align-items:center;">
                  <a href="{{ item.url }}" style="flex-shrink:0; width:80px; height:80px; border-radius:8px; overflow:hidden; background:#f7f7f7; display:block;">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.image.alt | escape }}" width="80" height="80" loading="lazy" style="width:100%; height:100%; object-fit:contain;">
                    {%- endif -%}
                  </a>
                  <div>
                    <a href="{{ item.url }}" style="font-size:15px; color:#222; text-decoration:none; font-weight:400;">{{ item.product.title | escape }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p style="font-size:13px; color:#666; margin:4px 0 0;">{{ item.variant.title | escape }}</p>
                    {%- endunless -%}
                    <button
                      type="button"
                      class="remove-item"
                      data-index="{{ item.index | plus: 1 }}"
                      style="background:none; border:none; color:#999; font-size:12px; cursor:pointer; padding:4px 0; margin-top:4px; text-decoration:underline;"
                    >
                      Ta bort
                    </button>
                  </div>
                </div>
              </td>
              <td style="padding:20px 0; text-align:center; vertical-align:middle;">
                <div style="display:inline-flex; align-items:center; border:1px solid #e2e2e2; border-radius:25px; overflow:hidden;">
                  <button type="button" class="qty-btn" data-index="{{ item.index | plus: 1 }}" data-action="decrease" style="width:36px; height:36px; background:transparent; border:none; font-size:16px; cursor:pointer; color:#444;">−</button>
                  <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Antal" data-index="{{ item.index | plus: 1 }}" style="width:40px; height:36px; text-align:center; border:none; font-size:14px; -moz-appearance:textfield; outline:none;">
                  <button type="button" class="qty-btn" data-index="{{ item.index | plus: 1 }}" data-action="increase" style="width:36px; height:36px; background:transparent; border:none; font-size:16px; cursor:pointer; color:#444;">+</button>
                </div>
              </td>
              <td style="padding:20px 0; text-align:right; vertical-align:middle;">
                <span style="font-size:15px; color:#222;">{{ item.line_price | money }}</span>
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </form>
  {%- endif -%}
</section>

<script>
(function() {
  // Quantity buttons in cart
  document.querySelectorAll('.qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = this.dataset.index;
      var input = document.querySelector('input[data-index="' + idx + '"]');
      var val = parseInt(input.value) || 1;
      if (this.dataset.action === 'increase') { input.value = val + 1; }
      else { input.value = Math.max(0, val - 1); }
    });
  });

  // Remove item via AJAX
  document.querySelectorAll('.remove-item').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = this.dataset.index;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: idx, quantity: 0 })
      }).then(function() { window.location.reload(); });
    });
  });
})();
</script>

{% schema %}
{
  "name": "Cart items",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
