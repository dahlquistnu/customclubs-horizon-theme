<section class="startpage-categories--top" style="background:#001914; padding-bottom:0;">
  <div style="overflow-x:auto; -webkit-overflow-scrolling:touch;">
    <ul class="startpage-cat-list" role="list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <li class="startpage-category-item" {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.link }}"
                class="startpage-category-item__link"
                style="display:block; position:relative; text-decoration:none; overflow:hidden; border-radius:8px;"
              >
                <div class="startpage-category-item__img" style="height:270px; min-width:200px; overflow:hidden; background:#00352B;">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 500 }}"
                      srcset="{{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 700 }} 700w"
                      sizes="(max-width: 750px) 200px, 280px"
                      alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                      width="500"
                      height="270"
                      loading="lazy"
                      style="width:100%; height:100%; object-fit:cover; transition:opacity 0.2s;"
                    >
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>

                {%- if block.settings.title != blank -%}
                  <div style="position:absolute; bottom:14px; left:14px;">
                    <span class="startpage-category-item__label">{{ block.settings.title | escape }}</span>
                  </div>
                {%- endif -%}
              </a>
            </li>
        {%- endcase -%}
      {%- endfor -%}
    </ul>
  </div>
</section>

<style>
  .startpage-cat-list {
    display: flex;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0 15px 30px;
    max-width: 1500px;
    margin-inline: auto;
    flex-wrap: nowrap;
  }
  .startpage-category-item {
    flex: 1;
    min-width: 200px;
    -webkit-tap-highlight-color: transparent;
  }
  .startpage-category-item__img img:hover,
  .startpage-category-item__img img:active { opacity: 0.8; }
  .startpage-category-item__label {
    display: inline-block;
    background: rgba(0, 25, 20, 0.8);
    color: #fff;
    font-size: 14px;
    font-weight: 400;
    padding: 8px 16px;
    border-radius: 50px;
    border: 1px solid rgba(255,255,255,0.4);
    backdrop-filter: blur(4px);
    white-space: nowrap;
  }
  @media (max-width: 750px) {
    .startpage-cat-list { flex-wrap: nowrap; padding-inline: 10px; }
    .startpage-category-item { min-width: 160px; }
    .startpage-category-item__img { height: 220px !important; }
  }
</style>

{% schema %}
{
  "name": "Category Tiles",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Drivers"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Tiles",
      "blocks": [
        { "type": "category", "settings": { "title": "Wedgar" } },
        { "type": "category", "settings": { "title": "Drivers" } },
        { "type": "category", "settings": { "title": "Fairwaywoods" } },
        { "type": "category", "settings": { "title": "Hybrider/Utility" } },
        { "type": "category", "settings": { "title": "Järnset" } }
      ]
    }
  ]
}
{% endschema %}
