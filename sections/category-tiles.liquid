<section class="category-tiles section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="category-tiles__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <ul class="category-tiles__grid" role="list" style="
      display: grid;
      grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
      gap: 16px;
      list-style: none;
      padding: 0;
      margin: 0;
    ">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'category' -%}
            <li class="category-tile" {{ block.shopify_attributes }}>
              <a
                href="{{ block.settings.link }}"
                class="category-tile__link"
                style="
                  display: block;
                  border-radius: 8px;
                  overflow: hidden;
                  position: relative;
                  aspect-ratio: 3/4;
                  background-color: #001914;
                  text-decoration: none;
                "
              >
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 500 }}"
                    srcset="{{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 500 }} 500w"
                    sizes="(max-width: 750px) 50vw, (max-width: 990px) 33vw, 20vw"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    loading="lazy"
                    style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}

                <div style="
                  position: absolute;
                  bottom: 0;
                  left: 0;
                  right: 0;
                  padding: 16px;
                  background: linear-gradient(transparent, rgba(0,25,20,0.85));
                ">
                  <span style="
                    color: #ffffff;
                    font-size: 15px;
                    font-weight: 500;
                    display: block;
                  ">{{ block.settings.title }}</span>
                </div>
              </a>
            </li>
        {%- endcase -%}
      {%- endfor -%}
    </ul>
  </div>
</section>

<style>
  .category-tile__link:hover img {
    transform: scale(1.04);
  }

  @media (max-width: 750px) {
    .category-tiles__grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 480px) {
    .category-tiles__grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 10px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Category Tiles",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shoppa efter kategori"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 3,
      "max": 6,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Drivers"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Tiles",
      "blocks": [
        { "type": "category", "settings": { "title": "Drivers" } },
        { "type": "category", "settings": { "title": "Fairwaywoods" } },
        { "type": "category", "settings": { "title": "Järnset" } },
        { "type": "category", "settings": { "title": "Wedgar" } },
        { "type": "category", "settings": { "title": "Putters" } }
      ]
    }
  ]
}
{% endschema %}
