<section class="brand-logos" style="background:#fff; padding-block:48px; border-top:1px solid #e2e2e2;">
  <div style="max-width:1400px; margin:0 auto; padding-inline:15px;">
    {%- if section.settings.heading != blank -%}
      <h2 style="font-size:22px; font-weight:400; color:#001914; margin:0 0 32px; text-align:center;">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="brand-logos__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand' -%}
            <div class="brand-logos__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" style="display:block;">{%- endif -%}
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ block.settings.name | escape }}"
                    width="120"
                    height="60"
                    loading="lazy"
                    style="width:100%; max-width:120px; height:auto; object-fit:contain; filter:grayscale(100%); opacity:0.6; transition:filter 0.2s, opacity 0.2s;"
                  >
                {%- else -%}
                  <span style="font-size:15px; font-weight:500; color:#666;">{{ block.settings.name | escape }}</span>
                {%- endif -%}
              {%- if block.settings.link != blank -%}</a>{%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .brand-logos__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 24px 40px;
    align-items: center;
    justify-content: center;
  }
  .brand-logos__item { display: flex; align-items: center; justify-content: center; }
  .brand-logos__item img:hover { filter: grayscale(0%) !important; opacity: 1 !important; }
</style>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section",
  "max_blocks": 30,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Våra varumärken"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "TaylorMade"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
        { "type": "brand", "settings": { "name": "TaylorMade" } },
        { "type": "brand", "settings": { "name": "Titleist" } },
        { "type": "brand", "settings": { "name": "Callaway" } },
        { "type": "brand", "settings": { "name": "Mizuno" } },
        { "type": "brand", "settings": { "name": "Ping" } },
        { "type": "brand", "settings": { "name": "Cleveland" } },
        { "type": "brand", "settings": { "name": "Srixon" } },
        { "type": "brand", "settings": { "name": "PXG" } }
      ]
    }
  ]
}
{% endschema %}
