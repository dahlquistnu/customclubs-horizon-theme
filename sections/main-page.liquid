<section class="main-page page-width" style="padding-block:48px; max-width:800px;">
  <h1 style="font-size:32px; font-weight:400; color:#001914; margin:0 0 24px;">{{ page.title | escape }}</h1>
  <div style="font-size:15px; line-height:1.8; color:#444;">
    {{ page.content }}
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section",
  "settings": []
}
{% endschema %}
