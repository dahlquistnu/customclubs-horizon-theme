<section class="main-blog page-width" style="padding-block:40px;">
  <h1 style="font-size:32px; font-weight:400; color:#001914; margin:0 0 32px;">{{ blog.title | escape }}</h1>

  {%- paginate blog.articles by 12 -%}
    <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:24px;">
      {%- for article in blog.articles -%}
        <article style="border-radius:8px; overflow:hidden; border:1px solid #e2e2e2; background:#fff;">
          {%- if article.image -%}
            <a href="{{ article.url }}" style="display:block; aspect-ratio:16/9; overflow:hidden; background:#f7f7f7;">
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.image.alt | escape }}" loading="lazy" style="width:100%; height:100%; object-fit:cover; transition:transform 0.3s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''">
            </a>
          {%- endif -%}
          <div style="padding:16px;">
            <p style="font-size:12px; color:#999; margin:0 0 8px;">{{ article.published_at | date: '%d %b %Y' }}</p>
            <h2 style="font-size:16px; font-weight:500; color:#222; margin:0 0 8px; line-height:1.3;">
              <a href="{{ article.url }}" style="text-decoration:none; color:inherit;">{{ article.title | escape }}</a>
            </h2>
            <p style="font-size:13px; color:#666; margin:0 0 12px; line-height:1.5;">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
            <a href="{{ article.url }}" style="font-size:13px; color:#00352B; font-weight:500;">Läs mer &rarr;</a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div style="display:flex; justify-content:center; gap:8px; margin-top:40px;">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" style="height:40px; padding:0 16px; border-radius:70px; border:1px solid #e2e2e2; display:inline-flex; align-items:center; font-size:14px; color:#222; text-decoration:none;">&larr;</a>{%- endif -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" style="height:40px; padding:0 16px; border-radius:70px; border:1px solid #e2e2e2; display:inline-flex; align-items:center; font-size:14px; color:#222; text-decoration:none;">&rarr;</a>{%- endif -%}
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</section>

<style>
  @media (max-width: 750px) { .main-blog > div { grid-template-columns: 1fr !important; } }
</style>

{% schema %}
{ "name": "Blog posts", "tag": "section", "class": "section", "settings": [] }
{% endschema %}
