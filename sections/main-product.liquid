<section class="main-product page-width" style="padding-block:40px;">
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start;">

    {%- comment -%} Gallery {%- endcomment -%}
    <div class="product__gallery">
      <div id="product-main-image" style="border-radius:12px; overflow:hidden; background:#f7f7f7; aspect-ratio:1; margin-bottom:12px;">
        {%- if product.featured_image -%}
          <img
            id="main-product-img"
            src="{{ product.featured_image | image_url: width: 900 }}"
            srcset="{{ product.featured_image | image_url: width: 600 }} 600w, {{ product.featured_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 750px) 100vw, 50vw"
            alt="{{ product.featured_image.alt | default: product.title | escape }}"
            width="900"
            height="900"
            loading="eager"
            fetchpriority="high"
            style="width:100%; height:100%; object-fit:contain;"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div style="display:flex; gap:8px; flex-wrap:wrap;">
          {%- for image in product.images limit: 6 -%}
            <button
              class="product-thumb"
              data-src="{{ image | image_url: width: 900 }}"
              style="width:72px; height:72px; border-radius:8px; overflow:hidden; border:2px solid {% if forloop.first %}#00E697{% else %}#e2e2e2{% endif %}; background:#f7f7f7; cursor:pointer; padding:0; flex-shrink:0; transition:border-color 0.15s;"
            >
              <img
                src="{{ image | image_url: width: 144 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
                width="72"
                height="72"
                style="width:100%; height:100%; object-fit:contain;"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Product info {%- endcomment -%}
    <div class="product__info">
      {%- if product.vendor != blank and section.settings.show_vendor -%}
        <p style="font-size:12px; color:#999; text-transform:uppercase; letter-spacing:0.08em; margin:0 0 8px;">{{ product.vendor | escape }}</p>
      {%- endif -%}

      <h1 class="product__title" style="font-size:28px; font-weight:400; color:#001914; margin:0 0 16px; line-height:1.2;">
        {{ product.title | escape }}
      </h1>

      {%- comment -%} Price {%- endcomment -%}
      <div id="price-{{ section.id }}" class="product__price" style="margin-bottom:24px;" role="status">
        {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
          <span style="font-size:26px; font-weight:500; color:#222;">{{ product.selected_or_first_available_variant.price | money }}</span>
          <span style="font-size:16px; color:#999; text-decoration:line-through; margin-left:10px;">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
        {%- else -%}
          <span style="font-size:26px; font-weight:500; color:#222;">{{ product.selected_or_first_available_variant.price | money }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Variants {%- endcomment -%}
      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div style="margin-bottom:20px;">
            <p style="font-size:13px; font-weight:500; color:#444; margin:0 0 8px;">
              {{ option.name }}:
              <span id="option-value-{{ forloop.index }}" style="font-weight:400; color:#222;">{{ option.selected_value | escape }}</span>
            </p>
            <div style="display:flex; gap:8px; flex-wrap:wrap;">
              {%- for value in option.values -%}
                <label style="cursor:pointer;">
                  <input
                    type="radio"
                    name="option-{{ option.position }}"
                    value="{{ value | escape }}"
                    {% if option.selected_value == value %}checked{% endif %}
                    style="display:none;"
                  >
                  <span
                    class="variant-btn"
                    style="display:inline-block; padding:7px 16px; border:1px solid {% if option.selected_value == value %}#00E697{% else %}#e2e2e2{% endif %}; border-radius:6px; font-size:13px; color:#222; background:{% if option.selected_value == value %}#00E697{% else %}#fff{% endif %}; color:{% if option.selected_value == value %}#001914{% else %}#222{% endif %}; transition:all 0.15s;"
                  >
                    {{ value | escape }}
                  </span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      {%- comment -%} Add to cart form {%- endcomment -%}
      {%- form 'product', product, id: 'product-form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- comment -%} Quantity {%- endcomment -%}
        {%- if section.settings.show_quantity -%}
          <div style="margin-bottom:16px;">
            <label for="quantity" style="display:block; font-size:13px; color:#444; margin-bottom:6px;">Antal</label>
            <div style="display:flex; align-items:center; border:1px solid #e2e2e2; border-radius:25px; width:fit-content; overflow:hidden;">
              <button type="button" class="qty-btn" data-action="decrease" style="width:40px; height:40px; background:transparent; border:none; font-size:18px; cursor:pointer; color:#444;">−</button>
              <input type="number" id="quantity" name="quantity" min="1" value="1" style="width:44px; height:40px; text-align:center; border:none; font-size:15px; -moz-appearance:textfield; outline:none;">
              <button type="button" class="qty-btn" data-action="increase" style="width:40px; height:40px; background:transparent; border:none; font-size:18px; cursor:pointer; color:#444;">+</button>
            </div>
          </div>
        {%- endif -%}

        <button
          type="submit"
          name="add"
          id="add-to-cart-btn"
          class="product-form__submit"
          {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
          style="width:100%; height:56px; border-radius:70px; background:#00352B; color:#00E697; border:none; font-size:16px; font-weight:500; cursor:pointer; transition:background 0.2s; margin-bottom:12px;"
        >
          {%- if product.selected_or_first_available_variant.available -%}
            Lägg i kundvagnen
          {%- else -%}
            Slutsåld
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- comment -%} Description {%- endcomment -%}
      {%- if product.description != blank -%}
        <div class="product__description" style="margin-top:32px; padding-top:24px; border-top:1px solid #e2e2e2;">
          <h2 style="font-size:16px; font-weight:500; color:#222; margin:0 0 12px;">Produktbeskrivning</h2>
          <div style="font-size:14px; line-height:1.7; color:#444;">
            {{ product.description }}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  @media (max-width: 750px) {
    .main-product > div { grid-template-columns: 1fr !important; }
  }
  .product-form__submit:hover { background: #00483a !important; }
  .product-form__submit:disabled { background: #999 !important; color: #fff !important; cursor: not-allowed !important; }
</style>

<script>
(function() {
  // Thumbnail switcher
  document.querySelectorAll('.product-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var src = this.dataset.src;
      var mainImg = document.getElementById('main-product-img');
      if (mainImg) mainImg.src = src;
      document.querySelectorAll('.product-thumb').forEach(function(b) { b.style.borderColor = '#e2e2e2'; });
      this.style.borderColor = '#00E697';
    });
  });

  // Quantity buttons
  document.querySelectorAll('.qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = document.getElementById('quantity');
      var val = parseInt(input.value) || 1;
      if (this.dataset.action === 'increase') { input.value = val + 1; }
      else if (val > 1) { input.value = val - 1; }
    });
  });

  // Variant selection
  var variantData = {{ product.variants | json }};
  document.querySelectorAll('input[type="radio"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
      // Update label styles
      var name = this.name;
      document.querySelectorAll('input[name="' + name + '"]').forEach(function(r) {
        var span = r.nextElementSibling;
        if (r.checked) {
          span.style.borderColor = '#00E697';
          span.style.background = '#00E697';
          span.style.color = '#001914';
        } else {
          span.style.borderColor = '#e2e2e2';
          span.style.background = '#fff';
          span.style.color = '#222';
        }
      });

      // Find matching variant
      var selected = {};
      document.querySelectorAll('input[type="radio"]:checked').forEach(function(r) {
        var idx = r.name.replace('option-', '');
        selected[idx] = r.value;
      });

      var match = variantData.find(function(v) {
        return Object.keys(selected).every(function(i) {
          return v['option' + i] === selected[i];
        });
      });

      if (match) {
        document.getElementById('variant-id').value = match.id;
        var btn = document.getElementById('add-to-cart-btn');
        if (match.available) {
          btn.disabled = false;
          btn.textContent = 'Lägg i kundvagnen';
          btn.style.background = '#00352B';
          btn.style.color = '#00E697';
        } else {
          btn.disabled = true;
          btn.textContent = 'Slutsåld';
        }
        // Update price
        var priceEl = document.getElementById('price-{{ section.id }}');
        if (priceEl) {
          var price = (match.price / 100).toFixed(2).replace('.', ',') + ' kr';
          var html = '<span style="font-size:26px;font-weight:500;color:#222;">' + price + '</span>';
          if (match.compare_at_price > match.price) {
            var comparePrice = (match.compare_at_price / 100).toFixed(2).replace('.', ',') + ' kr';
            html += '<span style="font-size:16px;color:#999;text-decoration:line-through;margin-left:10px;">' + comparePrice + '</span>';
          }
          priceEl.innerHTML = html;
        }
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Product information",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    }
  ]
}
{% endschema %}
