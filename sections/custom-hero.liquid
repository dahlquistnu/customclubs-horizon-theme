<section class="startpage-top-box" style="background:#001914; padding-block:60px; margin-bottom:0;">
  <div style="max-width:1500px; margin:0 auto; padding-inline:15px;">
    <div class="startpage-top-text">
      <div class="hero-grid">
        <div class="hero-grid__left">
          <h1 class="hero-heading">
            <strong>{{ section.settings.heading_highlight | escape }}</strong><br>
            {{ section.settings.heading_rest | escape }}
          </h1>
        </div>
        <div class="hero-grid__right">
          {%- if section.settings.subheading != blank -%}
            <p class="hero-subheading">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: flex;
    gap: 9%;
    align-items: center;
  }
  .hero-grid__left,
  .hero-grid__right { flex: 1; }
  .hero-heading {
    font-size: 88px;
    font-weight: 400;
    line-height: 1;
    color: #fff;
    margin: 0;
  }
  .hero-heading strong {
    color: #00E697;
    font-weight: 400;
    display: block;
  }
  .hero-subheading {
    font-size: 24px;
    line-height: 1.5;
    color: #fff;
    margin: 0;
  }
  @media (max-width: 768px) {
    .hero-grid { flex-wrap: wrap; gap: 24px; }
    .hero-heading { font-size: 60px; }
    .hero-subheading { font-size: 18px; }
  }
  @media (max-width: 480px) {
    .hero-heading { font-size: 48px; }
    .startpage-top-box { padding-block: 36px !important; }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading_highlight",
      "default": "Customize",
      "label": "Heading (green part)"
    },
    {
      "type": "text",
      "id": "heading_rest",
      "default": "your passion",
      "label": "Heading (white part)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "default": "När detaljer spelar roll skapar vi golfklubbor som gör skillnad. Vi kombinerar passion och precision för att skapa golfklubbor som är unikt anpassade för dig.",
      "label": "Subheading text"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "heading_highlight": "Customize",
        "heading_rest": "your passion"
      }
    }
  ]
}
{% endschema %}
