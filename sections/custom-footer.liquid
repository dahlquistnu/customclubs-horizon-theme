<footer class="footer">
  <div class="page-width">
    <div class="footer__content-top">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'logo' -%}
            <div class="footer__logo-column" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <a href="{{ routes.root_url }}" style="display: block; margin-bottom: 16px;">
                  <img
                    src="{{ block.settings.image | image_url: width: 200 }}"
                    alt="{{ shop.name | escape }}"
                    width="200"
                    height="60"
                    style="max-height: 60px; width: auto;"
                  >
                </a>
              {%- else -%}
                <a href="{{ routes.root_url }}" style="font-size: 20px; font-weight: 600; color: #00E697; display: block; margin-bottom: 16px;">
                  {{ shop.name }}
                </a>
              {%- endif -%}
              {%- if block.settings.tagline != blank -%}
                <p style="font-size: 13px; color: rgba(255,255,255,0.6); margin: 0 0 16px;">{{ block.settings.tagline }}</p>
              {%- endif -%}

              {%- if block.settings.show_newsletter -%}
                <p class="footer__heading" style="margin-bottom: 8px;">{{ block.settings.newsletter_label | default: 'Nyhetsbrev' }}</p>
                <form class="footer__newsletter-form" method="post" action="/contact#contact_form">
                  <input type="email" name="contact[email]" placeholder="Din e-post" required>
                  <button type="submit">Prenumerera</button>
                </form>
              {%- endif -%}
            </div>

          {%- when 'link_list' -%}
            <div class="footer__link-column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="footer__heading">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer__list" style="list-style: none; padding: 0; margin: 0;">
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="footer__text-column" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <p class="footer__heading">{{ block.settings.heading }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div style="font-size: 13px; color: rgba(255,255,255,0.7); line-height: 1.6;">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__content-bottom">
      <span>
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        </span>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment-icons" style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "blocks": [
    {
      "type": "logo",
      "name": "Logo & Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Bygg din golfklubba online"
        },
        {
          "type": "checkbox",
          "id": "show_newsletter",
          "label": "Show newsletter signup",
          "default": true
        },
        {
          "type": "text",
          "id": "newsletter_label",
          "label": "Newsletter label",
          "default": "Nyhetsbrev"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Snabblänkar"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Kontakt"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Custom Clubs Sweden AB<br>info@customclubs.se<br>+46 000 000 000</p>"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "logo" },
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
