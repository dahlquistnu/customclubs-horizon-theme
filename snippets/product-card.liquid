{% comment %}
  Renders a product card.
  Usage: {% render 'product-card', product: product, show_vendor: false %}
{% endcomment %}

{%- assign show_vendor = show_vendor | default: false -%}

<div class="card product-card" style="border-radius:8px; overflow:hidden; background:#fff; border:1px solid #e2e2e2; transition:box-shadow 0.2s; position:relative; height:100%;">
  <a href="{{ product.url }}" style="display:flex; flex-direction:column; height:100%; text-decoration:none; color:inherit;">

    {%- comment -%} Badge {%- endcomment -%}
    {%- if product.compare_at_price > product.price -%}
      {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <span style="position:absolute; top:8px; left:8px; background:#cc0000; color:#fff; font-size:11px; font-weight:600; padding:2px 8px; border-radius:4px; z-index:1;">
        -{{ discount }}%
      </span>
    {%- elsif product.available == false -%}
      <span style="position:absolute; top:8px; left:8px; background:#666; color:#fff; font-size:11px; font-weight:600; padding:2px 8px; border-radius:4px; z-index:1;">
        Slutsåld
      </span>
    {%- endif -%}

    {%- comment -%} Image {%- endcomment -%}
    <div style="aspect-ratio:1; overflow:hidden; background:#f7f7f7; flex-shrink:0;">
      {%- if product.featured_image -%}
        <img
          src="{{ product.featured_image | image_url: width: 500 }}"
          srcset="
            {{ product.featured_image | image_url: width: 300 }} 300w,
            {{ product.featured_image | image_url: width: 500 }} 500w,
            {{ product.featured_image | image_url: width: 700 }} 700w
          "
          sizes="(max-width: 480px) 50vw, (max-width: 990px) 33vw, 20vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          loading="lazy"
          width="500"
          height="500"
          style="width:100%; height:100%; object-fit:contain; transition:transform 0.3s ease;"
        >
      {%- else -%}
        <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#ccc;">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Info {%- endcomment -%}
    <div style="padding:12px; flex:1; display:flex; flex-direction:column; gap:4px;">
      {%- if show_vendor and product.vendor != blank -%}
        <p style="font-size:11px; color:#999; margin:0; text-transform:uppercase; letter-spacing:0.05em;">{{ product.vendor | escape }}</p>
      {%- endif -%}

      <h3 style="font-size:14px; font-weight:400; color:#222; margin:0; line-height:1.3;">
        {{ product.title | escape }}
      </h3>

      <div style="margin-top:auto; padding-top:8px;">
        {%- if product.compare_at_price > product.price -%}
          <span style="font-size:16px; color:#222; font-weight:500;">{{ product.price | money }}</span>
          <span style="font-size:13px; color:#999; text-decoration:line-through; margin-left:6px;">{{ product.compare_at_price | money }}</span>
        {%- else -%}
          <span style="font-size:16px; color:#222;">{{ product.price | money }}</span>
        {%- endif -%}
      </div>
    </div>
  </a>
</div>

<style>
  .product-card:hover { box-shadow: 0 0 12px rgba(0,0,0,0.1); }
  .product-card:hover img { transform: scale(1.04); }
</style>
